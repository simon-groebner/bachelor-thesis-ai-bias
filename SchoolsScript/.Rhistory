install.packages("corrplot")
library(corrplot)
# Compute correlation matrix between days
cor_matrix <- cor(tmax_clean)
# Create the correlation plot
corrplot(cor_matrix, method = "color", type = "upper",
tl.col = "black", tl.cex = 0.8,
title = "Correlation of July Tmax Between Days",
mar = c(0,0,2,0))
library(HDclassif)
install.packages("HDclassif")
library(HDclassif)
library(robustbase)
data(wine)
# Subset only class 1 wines
wine1 <- subset(wine, class == 1)
# Only keep V2 and V13
wine_vars <- wine1[, c("V2", "V13")]
plot(wine_vars,
main = "Scatterplot of V2 vs V13 (Wine Class 1)",
xlab = "V2", ylab = "V13",
pch = 19, col = "grey")
# Perform robust MCD estimation
mcd_result <- covMcd(wine_vars)
# Add the MCD-selected points in a different color (e.g., blue)
points(wine_vars[mcd_result$best, ],
col = "blue", pch = 19)
legend("topright", legend = c("All points", "MCD-selected"),
col = c("grey", "blue"), pch = 19)
wine_scaled <- scale(wine_vars)  # centers and scales both variables
mcd_scaled <- covMcd(wine_scaled)
# Original plot from unscaled data
plot(wine_vars, col = "grey", pch = 19,
main = "Comparison of MCD Best Subsets (Unscaled vs. Scaled)",
xlab = "V2", ylab = "V13")
# MCD best subset from unscaled data (task 4)
points(wine_vars[mcd_result$best, ], col = "blue", pch = 19)
# MCD best subset from scaled data (task 5)
points(wine_vars[mcd_scaled$best, ], col = "red", pch = 1, lwd = 2)
legend("topright", legend = c("All", "MCD (unscaled)", "MCD (scaled)"),
col = c("grey", "blue", "red"), pch = c(19, 19, 1), pt.lwd = c(1, 1, 2))
wine_scaled <- scale(wine_vars)  # centers and scales both variables
mcd_scaled <- covMcd(wine_scaled)
# Original plot from unscaled data
plot(wine_vars, col = "grey", pch = 19,
main = "Comparison of MCD Best Subsets (Unscaled vs. Scaled)",
xlab = "V2", ylab = "V13")
# MCD best subset from unscaled data (task 4)
points(wine_vars[mcd_result$best, ], col = "blue", pch = 19)
# MCD best subset from scaled data (task 5)
points(wine_vars[mcd_scaled$best, ], col = "red", pch = 1, lwd = 2)
legend("topright", legend = c("All", "MCD (unscaled)", "MCD (scaled)"),
col = c("grey", "blue", "red"), pch = c(19, 19, 1), pt.lwd = c(1, 1, 2))
wine1 <- subset(wine, class == 1)
wine1_data <- wine1[, -1]  # remove the class column
cor_sample <- cor(wine1_data)
# Apply MCD to the full dataset
mcd_result <- covMcd(wine1_data)
# Convert robust covariance matrix to correlation matrix
cov_mcd <- mcd_result$cov
cor_mcd <- cov2cor(cov_mcd)
# Classical correlation matrix
corrplot(cor_sample, main = "Classical Correlation Matrix")
# Robust (MCD-based) correlation matrix
corrplot(cor_mcd, main = "Robust Correlation Matrix (MCD)")
View(wine)
View(wine)
View(wine1_data)
View(wine1_data)
mcd_result <- covMcd(wine1_data)
weights <- mcd_result$mcd.wt  # 1 = non-outlier, 0 = outlier
colors <- ifelse(weights == 1, "black", "red")  # red for outliers
pairs(wine1_data,
col = colors,
pch = 19,
main = "Scatterplot Matrix with MCD Outlier Weights (Red = Outliers)")
mcd_result <- covMcd(wine1_data)
md <- mahalanobis(wine1_data,
center = mcd_result$center,
cov = mcd_result$cov)
colors <- ifelse(mcd_result$mcd.wt == 1, "black", "red")  # red = outlier
p <- ncol(wine1_data)  # number of variables
cutoff <- qchisq(0.975, df = p)
plot(md, pch = 19, col = colors,
main = "Mahalanobis Distances (Robust via MCD)",
xlab = "Observation Index", ylab = "Mahalanobis Distance")
abline(h = cutoff, col = "blue", lwd = 2, lty = 2)
legend("topright", legend = c("Non-outlier", "Outlier", "Cutoff (97.5%)"),
col = c("black", "red", "blue"), pch = c(19, 19, NA), lty = c(NA, NA, 2))
mcd_result <- covMcd(wine1_data)
md <- mahalanobis(wine1_data,
center = mcd_result$center,
cov = mcd_result$cov)
colors <- ifelse(mcd_result$mcd.wt == 1, "black", "red")  # red = outlier
p <- ncol(wine1_data)  # number of variables
cutoff <- qchisq(0.975, df = p)
plot(md, pch = 19, col = colors,
main = "Mahalanobis Distances (Robust via MCD)",
xlab = "Observation Index", ylab = "Mahalanobis Distance")
abline(h = cutoff, col = "blue", lwd = 2, lty = 2)
legend("topleft", legend = c("Non-outlier", "Outlier", "Cutoff (97.5%)"),
col = c("black", "red", "blue"), pch = c(19, 19, NA), lty = c(NA, NA, 2))
center_classical <- colMeans(wine1_data)
cov_classical <- cov(wine1_data)
md_classical <- mahalanobis(wine1_data, center = center_classical, cov = cov_classical)
p <- ncol(wine1_data)
cutoff <- qchisq(0.975, df = p)
plot(md_classical, pch = 19, col = "black",
main = "Mahalanobis Distances (Classical Estimation)",
xlab = "Observation Index", ylab = "Mahalanobis Distance")
abline(h = cutoff, col = "blue", lwd = 2, lty = 2)
legend("topright", legend = c("Cutoff (97.5%)"),
col = "blue", lty = 2, lwd = 2)
