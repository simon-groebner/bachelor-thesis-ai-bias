library(aplpack)  # for faces()
install.packages('aplpack')
library(aplpack)  # for faces()
# Optional: reduce to a few years (too many faces gets messy)
sample_years <- seq(1990, 2024, by = 5)
sample_rows <- which((1990:2024) %in% sample_years)
faces(tmax_clean[sample_rows, ],
labels = as.character(1990:2024)[sample_rows],
main = "Chernoff Faces for July Tmax")
