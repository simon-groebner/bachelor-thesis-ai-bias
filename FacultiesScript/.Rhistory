ternaryDiag(fcm_result$membership, col = as.numeric(true_labels), pch = 19,
main = "Fuzzy Clustering - Ternary Plot (Color = True Wine Type)")
legend("topright", legend = levels(true_labels), col = 1:3, pch = 19)
# Load required packages
library(pgmm)
library(e1071)
library(robCompositions)
# Load and scale data
data(wine)
wine_scaled <- scale(wine[, -1])
true_labels <- as.factor(wine$Type)
# Apply fuzzy c-means clustering
fcm_result <- cmeans(wine_scaled, 3)
# Visualize membership coefficients with ternary plot
ternaryDiag(fcm_result$membership, col = as.numeric(true_labels), pch = 19,
main = "Fuzzy Clustering - Ternary Plot (Color = True Wine Type)")
legend("topright", legend = levels(true_labels), col = 1:3, pch = 19)
library(pgmm)
library(e1071)
library(robCompositions)
library(fossil)
# Load and scale data
data(wine)
wine_scaled <- scale(wine[, -1])
true_labels <- wine$Type
# Apply fuzzy clustering with lower fuzziness (e.g. m = 1.2)
set.seed(123)
fcm_result <- cmeans(wine_scaled, centers = 3, m = 1.2)
# Visualize ternary plot
ternaryDiag(fcm_result$membership, col = as.numeric(true_labels), pch = 19,
main = "Fuzzy Clustering (m = 1.2) - Ternary Plot")
legend("topright", legend = levels(as.factor(true_labels)), col = 1:3, pch = 19)
# Assign clusters using max membership
crisp_labels <- apply(fcm_result$membership, 1, which.max)
# Compute Rand index
rand_idx <- rand.index(crisp_labels, true_labels)
print(paste("Rand index (m = 1.2):", rand_idx))
