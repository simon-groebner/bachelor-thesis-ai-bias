# Load the data
load("darwinM.RData")
# View structure (optional, to understand what's inside)
str(darwinM)
# Remove the class label (assumed to be the last column)
data_no_class <- darwinM[, -ncol(darwinM)]
# Apply PCA with correlation matrix (standardizing variables)
pca_result <- princomp(data_no_class, cor = TRUE)
# Summary of PCA results (variance explained)
summary(pca_result)
# Plot scree plot (to see how much variance each PC explains)
screeplot(pca_result, type = "lines", main = "Screeplot of Darwin Data")
# Optional: biplot (scores and loadings together)
biplot(pca_result, main = "PCA Biplot (Scaled Data)")
View(darwinM)
